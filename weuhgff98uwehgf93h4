            bubble.Position = UDim2.new(0, 13, 0, 28)
            bubble.Size = UDim2.new(0, 27.18, 0, 17.46)
            bubble.BackgroundTransparency = 1
            bubble.BackgroundColor3 = Color3.fromRGB(27, 30, 33)
            bubble.BorderSizePixel = 0
