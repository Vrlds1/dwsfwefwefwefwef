                typingPulseTween = up
                up:Play()
                up.Completed:Connect(function()
                    if myToken ~= typingPulseToken then
                        return
                    end
                    local down = TweenService:Create(commandScale, TweenInfo.new(0.10, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
                        Scale = 1,
                    })
                    typingPulseTween = down
                    down:Play()
                end)
            end

