        -- Call this after creating your UI tabs if you want to include added commands
        -- Usage: local commandsTab = gui.createCommandsTab()
        createCommandsTab = function()
            if not builderApi then
                warn("createCommandsTab: builder API not available")
                return nil
            end
            
            local addedCommands = _G.AsteriaAddedCommands or {}
            local hasCommands = false
            for _ in pairs(addedCommands) do
                hasCommands = true
                break
            end
            
            if not hasCommands then
                return nil
            end
            
            -- Create Commands tab
            local commandsTab = builderApi:Tab("Commands")
            if not commandsTab then
                warn("createCommandsTab: failed to create Commands tab")
                return nil
            end
            
            -- Create Modules header
            local modulesHeader = commandsTab:Header({
                name = "Modules",
                icon = "rbxassetid://10723407389",
                side = "left",
                height = 200,
            })
            
            if not modulesHeader then
                warn("createCommandsTab: failed to create Modules header")
                return nil
            end
            
            -- Add toggles for each added command
            for cmdName, cmdInfo in pairs(addedCommands) do
                local spec = commandSpecs[cmdName]
                if spec and spec.run then
                    modulesHeader:Toggle({
                        name = cmdInfo.displayName or cmdName,
                        keybind = true,
                        default = cmdInfo.enabled or false,
                        purpose = cmdInfo.description or "Toggle command",
                        callback = function(on)
                            cmdInfo.enabled = on
                            -- Run the command (toggles typically toggle themselves)
                            spec.run({})
                        end,
                    })
                end
            end
            
            return commandsTab
        end,
        
        -- Add a single command toggle to an existing header
        -- Usage: gui.addCommandToggle(header, "sblink")
        addCommandToggle = function(header, cmdName)
            if not header or type(header.Toggle) ~= "function" then
                warn("addCommandToggle: header must have Toggle method")
                return nil
            end
            
            local spec = commandSpecs[cmdName]
            if not spec then
                warn("addCommandToggle: command not found:", cmdName)
                return nil
            end
            
            -- Toggleable command info
            local toggleableCommands = {
                sblink = { displayName = "Smart Blink", description = "Teleport to sky + blink + fly invisible" },
                blink = { displayName = "Blink", description = "Packet blink mode (Movement Only)" },
                allblink = { displayName = "All Blink", description = "Packet blink mode (All packets)" },
                tpwalk = { displayName = "TP Walk", description = "Teleport walking mode" },
                loopbringpart = { displayName = "Loop Bring Part", description = "Continuously bring a part" },
                fblink = { displayName = "Flight Blink", description = "Blink + fly without teleporting to sky" },
                fly = { displayName = "Fly", description = "Fly mode" },
                flyjump = { displayName = "Fly Jump", description = "Jump to fly" },
            }
            
            local info = toggleableCommands[cmdName] or { displayName = cmdName, description = spec.description or "" }
            
            return header:Toggle({
                name = info.displayName,
                keybind = true,
                default = false,
                purpose = info.description,
                callback = function(on)
                    spec.run({})
                end,
            })
        end,
        
        -- Create a new custom tab dynamically
        -- Usage: gui.createTab("MyTab") returns { name, page, section, container, addModule }
        createTab = function(tabName)
            if type(createDynamicTab) == "function" then
                return createDynamicTab(tabName)
            end
            return nil
        end,
        
        -- Get all custom tabs
        -- Usage: gui.getCustomTabs() returns { tabName = { page, section, container, modules } }
        getCustomTabs = function()
            return _G.AsteriaCustomTabs or {}
        end,
        
        -- Helper functions
        destroy = function()
            if keybindsDisplay and type(keybindsDisplay.Destroy) == "function" then
                pcall(function()
                    keybindsDisplay:Destroy()
                end)
            end
            screenGui:Destroy()
        end,
        
        hide = function()
            screenGui.Enabled = false
        end,
        
        show = function()
            screenGui.Enabled = true
        end,
        
        -- Add content to the content frame
        addContent = function(content)
            content.Parent = contentFrame
            return content
        end
    }
end

