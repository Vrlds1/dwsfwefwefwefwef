-- Generate random GUI name for security
local function generateRandomName()
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local name = ""
    for i = 1, 25 do
        local randomIndex = math.random(1, #chars)
        name = name .. chars:sub(randomIndex, randomIndex)
    end
    return name
end

-- Prevent TextBoxes from visually overflowing/breaking when text is long.
-- Uses TextTruncate when available; otherwise clips overflow.
local function applyTextboxNoBreak(textbox)
    if not (textbox and textbox:IsA("TextBox")) then
        return
    end

    textbox.TextWrapped = false
    textbox.TextScaled = false
    textbox.ClipsDescendants = true

    pcall(function()
        textbox.TextTruncate = Enum.TextTruncate.AtEnd
    end)
end

local function enableTextboxNoBreak(root)
    if not root then
        return
    end

    for _, inst in ipairs(root:GetDescendants()) do
        if inst:IsA("TextBox") then
            applyTextboxNoBreak(inst)
        end
    end

    root.DescendantAdded:Connect(function(inst)
        if inst:IsA("TextBox") then
            applyTextboxNoBreak(inst)
        end
    end)
end

