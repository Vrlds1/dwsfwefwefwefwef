            local function runBlockAdonis()
                -- Silent Adonis Bypass
                getgenv().debugInfo = false
                
                -- Hook kick protection
                local function installKickProtection()
                    if hookmetamethod then
                        local old
                        old = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
                            local method = getnamecallmethod()
                            if method == "Kick" then
                                return
                            end
                            return old(self, ...)
                        end))
                    end
                end
                
                -- Neutralize all AC tables
                local function neutralizeAdonisAC()
                    local neutralized = 0
                    local acTables = {}
                    local detectionSignatures = {
                        "newindexInstance",
                        "namecallInstance", 
                        "namecallEnum",
                        "indexInstance",
                        "indexEnum"
                    }
                    
                    for _, v in pairs(getgc(true)) do
                        if type(v) == "table" then
                            local matchCount = 0
                            
                            for _, sig in ipairs(detectionSignatures) do
                                if rawget(v, sig) then
                                    matchCount = matchCount + 1
                                end
                            end
                            
                            if matchCount >= 3 then
                                pcall(function()
                                    setreadonly(v, false)
                                    table.insert(acTables, v)
                                    
                                    if v.newindexInstance then v.newindexInstance = function() return false end end
                                    if v.namecallInstance then v.namecallInstance = function() return false end end
                                    if v.namecallEnum then v.namecallEnum = function() return false end end
                                    if v.indexInstance then v.indexInstance = function() return false end end
                                    if v.indexEnum then v.indexEnum = function() return false end end
                                    if v.methodDetect then v.methodDetect = function() return false end end
                                    if v.hookDetect then v.hookDetect = function() return false end end
                                    
                                    if v.tvk then v.tvk = nil end
                                    if v.Kick then v.Kick = function() end end
                                    if v.ban then v.ban = function() end end
                                    
                                    neutralized = neutralized + 1
                                end)
                            end
                        end
                    end
                    
                    return neutralized, acTables
                end
                
                -- Block Adonis remotes
                local function blockRemotes()
                    local blocked = 0
                    
                    pcall(function()
                        local RS = game:GetService("ReplicatedStorage")
                        local adonis = RS:FindFirstChild("HDAdminClient") or 
                                       RS:FindFirstChild("Adonis") or 
                                       RS:FindFirstChild("AdonisClient")
                        
                        if adonis and hookfunction then
                            for _, remote in pairs(adonis:GetDescendants()) do
                                if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                                    pcall(function()
                                        if remote:IsA("RemoteEvent") then
                                            hookfunction(remote.FireServer, function() end)
                                        else
                                            hookfunction(remote.InvokeServer, function() return nil end)
                                        end
                                        blocked = blocked + 1
                                    end)
                                end
                            end
                        end
                    end)
                end
                
                -- Execute silently
                pcall(function()
                    installKickProtection()
                    task.wait(0.1)
                    neutralizeAdonisAC()
                    task.wait(0.1)
                    blockRemotes()
                end)
                
                _G.AsteriaAdonisBlocked = true
                print("buh bye adonis")
