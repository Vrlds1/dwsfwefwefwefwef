            local maxV = tonumber(maxValue) or 100
            if maxV == minV then
                maxV = minV + 1
            end

            local currentValue = tonumber(defaultValue) or minV
            local currentRatio = math.clamp((currentValue - minV) / (maxV - minV), 0, 1)
            local targetRatio = currentRatio

