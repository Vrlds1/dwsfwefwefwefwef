            local function measureHintHeight(oneLineText)
                local width = commandContainer.AbsoluteSize.X
                if not width or width <= 0 then
                    width = 380
                end
                local usable = width - (HINT_PAD_X * 2) - 24
                if usable < 160 then
                    usable = 160
                end

                local titleSize = TextService:GetTextSize(tostring(oneLineText or ""), commandHintTitle.TextSize, commandHintTitle.Font, Vector2.new(usable, 1000))
                local titleH = math.clamp(math.ceil(titleSize.Y), HINT_TITLE_H, HINT_TITLE_H)
                commandHintTitle.Size = UDim2.new(1, -(HINT_PAD_X * 2), 0, titleH)
                return HINT_PAD_TOP + titleH + HINT_PAD_BOTTOM
            end

            local function escapeRichText(s)
                s = tostring(s or "")
                s = string.gsub(s, "&", "&amp;")
                s = string.gsub(s, "<", "&lt;")
                s = string.gsub(s, ">", "&gt;")
                return s
            end

            local function color3ToHex(c)
                local r = math.clamp(math.floor((c.R * 255) + 0.5), 0, 255)
                local g = math.clamp(math.floor((c.G * 255) + 0.5), 0, 255)
                local b = math.clamp(math.floor((c.B * 255) + 0.5), 0, 255)
                return string.format("#%02X%02X%02X", r, g, b)
            end

            local function updateCommandHint()
                local raw = tostring(commandInput.Text or "")
                local typed = normalizeCommandText(raw)
                typed = typed:match("^(%S+)") or ""

                -- Smooth typing feel + only pink when you're on-track to a real command.
                do
                    local onTrack = hasAnyCommandMatch(typed)
                    if onTrack then
                        tweenCommandInputTextColor(ACCENT_PRIMARY)
                    else
                        tweenCommandInputTextColor(Color3.fromRGB(230, 230, 235))
                    end
                end

                -- If the user typed something but it doesn't match any command prefix, show a friendly message.
                if typed ~= "" and (not hasAnyCommandMatch(typed)) then
                    local accentHex = color3ToHex(ACCENT_PRIMARY)
                    local mutedHex = color3ToHex(Color3.fromRGB(160, 160, 165))
                    local msgPlain = "hey sir; that's not a command"
                    local msgRich = string.format('<font color="%s">%s</font><font color="%s">; %s</font>', accentHex, escapeRichText("hey sir"), mutedHex, escapeRichText("that's not a command"))

                    commandHintTitle.Text = msgRich
                    commandHintDesc.Text = ""
                    local h = measureHintHeight(msgPlain)
                    setHintHeight(h)

                    ghostLabel.Text = ""
                    ghostLabel.Visible = false
                    
                    -- Clear tracked command
                    currentHintedCommand = nil
                    currentHintedSpec = nil
                    updateMiniKeybindDisplay(nil)
                    return
                end

                local matchName, matchSpec = getBestCommandMatch(typed)
                if not (matchName and matchSpec) then
                    ghostLabel.Text = ""
                    ghostLabel.Visible = false
                    setHintVisible(false)
                    
                    -- Clear tracked command
                    currentHintedCommand = nil
                    currentHintedSpec = nil
                    updateMiniKeybindDisplay(nil)
                    return
                end
                
                -- Track current hinted command for right-click feature
                currentHintedCommand = matchName
                currentHintedSpec = matchSpec
                
                -- Show mini keybind binder for toggleable commands
                if toggleableCommands[matchName] then
                    updateMiniKeybindDisplay(matchName)
                else
                    updateMiniKeybindDisplay(nil)
                end

                -- Under-bar hint: show suggested command + description.
                if typed ~= "" then
                    local desc = tostring(matchSpec.description or "")
                    -- Single-line style: `cmd; description`
                    local accentHex = color3ToHex(ACCENT_PRIMARY)
                    local mutedHex = color3ToHex(Color3.fromRGB(160, 160, 165))

                    local plainLine = matchName
                    local richLine = string.format('<font color="%s">%s</font>', accentHex, escapeRichText(matchName))
                    if desc ~= "" then
                        plainLine = matchName .. "; " .. desc
                        richLine = string.format('<font color="%s">%s</font><font color="%s">; %s</font>', accentHex, escapeRichText(matchName), mutedHex, escapeRichText(desc))
                    end
                    
                    -- Add right-click hint for toggleable commands
                    if toggleableCommands[matchName] then
                        richLine = richLine .. string.format(' <font color="#888888">(right-click to add)</font>')
                    end

                    commandHintTitle.Text = richLine
                    commandHintDesc.Text = ""
                    local h = measureHintHeight(plainLine)
                    setHintHeight(h)
                else
                    setHintVisible(false)
                end

                local ghost = tostring(matchSpec.ghost or matchName)
                if typed == "" or #ghost <= #typed or string.sub(ghost, 1, #typed) ~= typed then
                    ghostLabel.Text = ""
                    ghostLabel.Visible = false
                    return
                end

                -- Only show inline ghost when cursor is at end (keeps it from looking broken when editing mid-string)
                local cursorPos = tonumber(commandInput.CursorPosition) or (#raw + 1)
                if cursorPos ~= (#raw + 1) then
                    ghostLabel.Text = ""
                    ghostLabel.Visible = false
                    return
                end

                local rest = string.sub(ghost, #typed + 1)
                local renderedWidth = commandInput.TextBounds.X
                if (not renderedWidth) or renderedWidth <= 0 then
                    local fallback = TextService:GetTextSize(raw, commandInput.TextSize, commandInput.Font, Vector2.new(10000, 10000))
                    renderedWidth = fallback.X
                end

                ghostLabel.Position = UDim2.new(0, commandTextLeftPadding + renderedWidth, 0, 0)
                ghostLabel.Text = rest
                ghostLabel.Visible = true
            end

            local typingPulseTween = nil
            local typingPulseToken = 0
            local function pulseCommandBarOnType()
                if not commandOpen then
