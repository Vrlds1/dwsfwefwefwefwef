            bubbleStroke.Color = Color3.fromRGB(40, 43, 46)
            bubbleStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            bubbleStroke.LineJoinMode = Enum.LineJoinMode.Round
