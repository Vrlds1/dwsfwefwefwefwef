    -- TextBox hover/focus styling + clear button styling (ALL TEXTBOXES)
    do
        local TEXTBOX_BASE_STROKE_COLOR = Color3.fromRGB(55, 58, 61)
        local TEXTBOX_HOVER_STROKE_COLOR = Color3.fromRGB(160, 160, 165)
        local TEXTBOX_ACTIVE_STROKE_COLOR = ACCENT_PRIMARY -- pastel pink
        local TEXTBOX_DEFAULT_CLEAR_COLOR = Color3.fromRGB(160, 160, 165)

        local STROKE_IDLE_TRANSPARENCY = 0.4
        local STROKE_HOVER_TRANSPARENCY = 0.25
        local STROKE_FOCUS_TRANSPARENCY = 0.2
        local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        local strokeTweenByStroke = setmetatable({}, { __mode = "k" })
        local clearTransparencyTweenByButton = setmetatable({}, { __mode = "k" })
        local clearColorTweenByButton = setmetatable({}, { __mode = "k" })

        local function findClearButton(textbox)
            if not textbox then
                return nil
            end

            local byName = textbox:FindFirstChild("ClearButton")
            if byName and byName:IsA("ImageButton") then
                return byName
            end

            for _, child in ipairs(textbox:GetChildren()) do
                if child:IsA("ImageButton") then
                    if child.Image == "rbxassetid://9127564477" then
                        return child
                    end
                    -- Fallback: some older rows name this "ImageButton".
                    if child.Name == "ImageButton" then
                        return child
                    end
                end
            end

            return nil
        end

        local function getOrCreateStroke(textbox)
            local stroke = textbox:FindFirstChildWhichIsA("UIStroke")
            if stroke then
                return stroke
            end

            -- Only create a stroke if the UI is already using a clear button (outlined style).
            -- This avoids adding a border to textboxes that are intentionally borderless.
            if not findClearButton(textbox) then
                return nil
            end

            stroke = Instance.new("UIStroke")
            stroke.Name = "UIStroke"
            stroke.Thickness = 1
            stroke.Transparency = 0.4
            stroke.Color = TEXTBOX_BASE_STROKE_COLOR
            stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            stroke.LineJoinMode = Enum.LineJoinMode.Round
            stroke.Parent = textbox
            return stroke
        end

        local function bindTextBoxEffects(textbox)
            if not (textbox and textbox:IsA("TextBox")) then
                return
            end

            -- Keep the command bar styling untouched.
            if textbox.Name == "CommandInput" then
                return
            end

            if textbox:GetAttribute("AsteriaTextBoxEffectsBound") then
                return
            end
            textbox:SetAttribute("AsteriaTextBoxEffectsBound", true)

            local stroke = getOrCreateStroke(textbox)
            local clearButton = findClearButton(textbox)

            -- If a textbox has neither a stroke nor a clear button, there is nothing to style.
            if not stroke and not clearButton then
                return
            end

            local defaultStrokeThickness = stroke and stroke.Thickness or nil

            if stroke then
                stroke.Color = TEXTBOX_BASE_STROKE_COLOR
                stroke.Transparency = STROKE_IDLE_TRANSPARENCY
            end

            local hovered = false
            local focused = false

            local function tweenStroke(targetColor, targetTransparency)
                if not stroke then
                    return
                end

                local existing = strokeTweenByStroke[stroke]
                if existing then
                    existing:Cancel()
                end

                local tween = TweenService:Create(stroke, tweenInfo, {
                    Color = targetColor,
                    Transparency = targetTransparency,
                    Thickness = defaultStrokeThickness,
                })
                strokeTweenByStroke[stroke] = tween
                tween:Play()
            end

            local function setStrokeState()
                if not stroke then
                    return
                end

                if focused then
                    tweenStroke(TEXTBOX_ACTIVE_STROKE_COLOR, STROKE_FOCUS_TRANSPARENCY)
                elseif hovered then
                    tweenStroke(TEXTBOX_HOVER_STROKE_COLOR, STROKE_HOVER_TRANSPARENCY)
                else
                    tweenStroke(TEXTBOX_BASE_STROKE_COLOR, STROKE_IDLE_TRANSPARENCY)
                end
            end

            local function tweenClearTransparency(target)
                if not clearButton then
                    return
                end
                local existing = clearTransparencyTweenByButton[clearButton]
                if existing then
                    existing:Cancel()
                end
                local tween = TweenService:Create(clearButton, tweenInfo, {
                    ImageTransparency = target,
                })
                clearTransparencyTweenByButton[clearButton] = tween
                tween:Play()
            end

            local function tweenClearColor(target)
                if not clearButton then
                    return
                end
                local existing = clearColorTweenByButton[clearButton]
                if existing then
                    existing:Cancel()
                end
                local tween = TweenService:Create(clearButton, tweenInfo, {
                    ImageColor3 = target,
                })
                clearColorTweenByButton[clearButton] = tween
                tween:Play()
            end

            local function hasText()
                local t = textbox.Text
                return type(t) == "string" and #t > 0
            end

            local clearHovered = false

            local function updateClearVisibility()
                if not clearButton then
                    return
                end

                if not hasText() then
                    -- No text: never show the clear button.
                    clearButton.Visible = false
                    tweenClearTransparency(1)
                    return
                end

                -- Has text: clear button should exist/hover/click.
                clearButton.Visible = true

                -- Has text:
                -- - while typing (focused): show it
                -- - otherwise: keep hidden unless user hovers it
                if focused then
                    tweenClearTransparency(0)
                else
                    tweenClearTransparency(clearHovered and 0 or 1)
                end
            end

            -- Hover/focus state
            textbox.MouseEnter:Connect(function()
                hovered = true
                setStrokeState()
            end)

            textbox.MouseLeave:Connect(function()
                hovered = false
                setStrokeState()
            end)

            textbox.Focused:Connect(function()
                focused = true
                setStrokeState()
                updateClearVisibility()
            end)

            textbox.FocusLost:Connect(function()
                focused = false
                setStrokeState()
                updateClearVisibility()
            end)

            -- Clear button behavior
            if clearButton then
                if clearButton.ImageColor3 == nil then
                    clearButton.ImageColor3 = TEXTBOX_DEFAULT_CLEAR_COLOR
                end

                updateClearVisibility()

                textbox:GetPropertyChangedSignal("Text"):Connect(function()
                    updateClearVisibility()
                end)

                if not clearButton:GetAttribute("AsteriaClearButtonClickBound") then
                    clearButton:SetAttribute("AsteriaClearButtonClickBound", true)
                    clearButton.MouseButton1Click:Connect(function()
                        -- Clear and immediately focus the textbox so the user can type.
                        textbox.Text = ""
                        textbox:CaptureFocus()
                        updateClearVisibility()
                    end)
                end

                if not clearButton:GetAttribute("AsteriaClearButtonHoverBound") then
                    clearButton:SetAttribute("AsteriaClearButtonHoverBound", true)

                    local defaultClearColor = clearButton.ImageColor3 or TEXTBOX_DEFAULT_CLEAR_COLOR

                    clearButton.MouseEnter:Connect(function()
                        clearHovered = true
                        updateClearVisibility()
                        tweenClearColor(TEXTBOX_ACTIVE_STROKE_COLOR)
                    end)

                    clearButton.MouseLeave:Connect(function()
                        clearHovered = false
                        updateClearVisibility()
                        tweenClearColor(defaultClearColor)
                    end)
                end
            end

            -- Initialize to base state.
            setStrokeState()
        end

        local function bindAllTextBoxes(root)
            if not root then
                return
            end

            for _, d in ipairs(root:GetDescendants()) do
                if d:IsA("TextBox") then
                    bindTextBoxEffects(d)
                end
            end

            root.DescendantAdded:Connect(function(d)
                if d:IsA("TextBox") then
                    bindTextBoxEffects(d)
                end
            end)
        end

        -- Apply to current UI and any future TextBoxes created after this point.
        bindAllTextBoxes(screenGui)
    end

    -- Keybind capture (for KeybindButtons)
    local activeKeybindButton = nil
    local keybindOwnerByKeyName = {}
    local keybindChangedCallbackByButton = setmetatable({}, { __mode = "k" })

    local multiKeybindEnabled = false

    local menuToggleKeyButton = nil

    local keybindsDisplay = nil
    local showKeybindsCheckbox = nil
    local multiKeybindCheckbox = nil

    local keybindSizeTweenByButton = setmetatable({}, { __mode = "k" })
    local keybindLabelSizeTweenByLabel = setmetatable({}, { __mode = "k" })

    local function updateKeybindButtonSize(keybindButton, animate)
        if not keybindButton or not keybindButton:IsA("TextButton") then
            return
        end

        if animate == nil then
            animate = true
        end

        local text = keybindButton.Text or ""
        local ok, textSize = pcall(function()
            return TextService:GetTextSize(
                text,
                keybindButton.TextSize,
                keybindButton.Font,
                Vector2.new(1000, 20)
            )
        end)

        if not ok or typeof(textSize) ~= "Vector2" then
            return
        end

        local padding = 18
        local minWidth = 44
        local maxWidth = 130
        local targetWidth = math.clamp(math.ceil(textSize.X) + padding, minWidth, maxWidth)

        local targetKeybindSize = UDim2.new(0, targetWidth, 0, 20)

        if not animate then
            local existingSizeTween = keybindSizeTweenByButton[keybindButton]
            if existingSizeTween then
                existingSizeTween:Cancel()
                keybindSizeTweenByButton[keybindButton] = nil
            end
            keybindButton.Size = targetKeybindSize
        else
            -- Smooth, less harsh than the previous sizing tween.
            local sizeTweenInfo = TweenInfo.new(0.22, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

            local existingSizeTween = keybindSizeTweenByButton[keybindButton]
            if existingSizeTween then
                existingSizeTween:Cancel()
            end

            local sizeTween = TweenService:Create(keybindButton, sizeTweenInfo, {
                Size = targetKeybindSize,
            })
            keybindSizeTweenByButton[keybindButton] = sizeTween
            sizeTween:Play()
        end

        local toggleRow = keybindButton.Parent
        if toggleRow and toggleRow:IsA("Frame") then
            local label = toggleRow:FindFirstChild("Label")
            if label and label:IsA("TextLabel") then
                -- Base spacing: original 44px keybind roughly reserved 80px total => 44 + 36.
                local targetLabelSize = UDim2.new(1, -(targetWidth + 36), 1, 0)

                if not animate then
                    local existingLabelTween = keybindLabelSizeTweenByLabel[label]
                    if existingLabelTween then
                        existingLabelTween:Cancel()
                        keybindLabelSizeTweenByLabel[label] = nil
                    end
                    label.Size = targetLabelSize
                else
                    local sizeTweenInfo = TweenInfo.new(0.22, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

                    local existingLabelTween = keybindLabelSizeTweenByLabel[label]
                    if existingLabelTween then
                        existingLabelTween:Cancel()
                    end

                    local labelTween = TweenService:Create(label, sizeTweenInfo, {
                        Size = targetLabelSize,
                    })
                    keybindLabelSizeTweenByLabel[label] = labelTween
                    labelTween:Play()
                end
            end
        end
    end

    local function setKeybindButtonVisual(button, isCapturing)
        if not button then
            return
        end

        local stroke = button:FindFirstChildWhichIsA("UIStroke")

        if isCapturing then
            button:SetAttribute("AsteriaKeybindCapturing", true)
            button.TextColor3 = ACCENT_PRIMARY
            button.Text = "..."

            if stroke then
                local existing = strokeHoverTweenByStroke[stroke]
                if existing then
                    existing:Cancel()
                    strokeHoverTweenByStroke[stroke] = nil
                end
                stroke.Color = ACCENT_PRIMARY
                stroke.Transparency = 0.4
                stroke:SetAttribute("AsteriaKeybindCaptureTransparency", 0.4)
            end
            return
        end

        button:SetAttribute("AsteriaKeybindCapturing", false)

        local defaultTextColor = button:GetAttribute("AsteriaKeybindDefaultTextColor")
        local defaultText = button:GetAttribute("AsteriaKeybindDefaultText")

        local defaultStrokeColor = button:GetAttribute("AsteriaKeybindDefaultStrokeColor")
        local defaultStrokeTransparency = button:GetAttribute("AsteriaKeybindDefaultStrokeTransparency")

        if typeof(defaultTextColor) == "Color3" then
            button.TextColor3 = defaultTextColor
        end
        if type(defaultText) == "string" and button.Text == "..." then
            button.Text = defaultText
        end

        if stroke then
            local existing = strokeHoverTweenByStroke[stroke]
            if existing then
                existing:Cancel()
                strokeHoverTweenByStroke[stroke] = nil
            end

            if typeof(defaultStrokeColor) == "Color3" then
                stroke.Color = defaultStrokeColor
            else
                stroke.Color = Color3.fromRGB(55, 58, 61)
            end
            if type(defaultStrokeTransparency) == "number" then
                stroke.Transparency = defaultStrokeTransparency
            else
                stroke.Transparency = 0.4
            end
        end
    end

    local function bindKeybindButton(button)
        if not button or not button:IsA("TextButton") then
            return
        end

        if button:GetAttribute("AsteriaKeybindBound") then
            return
        end
        button:SetAttribute("AsteriaKeybindBound", true)

        if keybindsDisplay and button:GetAttribute("AsteriaKeybindsDisplayIgnore") ~= true then
            keybindsDisplay:AddButton(button)
        end

        button:SetAttribute("AsteriaKeybindDefaultTextColor", button.TextColor3)
        button:SetAttribute("AsteriaKeybindDefaultText", button.Text)

        -- Provide a stable label for the floating Keybinds display.
        do
            local row = button.Parent
            local rowLabel = row and row:FindFirstChild("Label")
            if rowLabel and rowLabel:IsA("TextLabel") then
                local function syncLabel()
                    local t = rowLabel.Text
                    if type(t) == "string" and t ~= "" then
                        button:SetAttribute("AsteriaKeybindLabelText", t)
                        if keybindsDisplay then
                            keybindsDisplay:ScheduleRefresh()
                        end
                    end
                end
                syncLabel()
                rowLabel:GetPropertyChangedSignal("Text"):Connect(syncLabel)
            end
        end

        local stroke = button:FindFirstChildWhichIsA("UIStroke")
        if stroke then
            button:SetAttribute("AsteriaKeybindDefaultStrokeColor", stroke.Color)
            button:SetAttribute("AsteriaKeybindDefaultStrokeTransparency", stroke.Transparency)
        end

        button.MouseButton1Click:Connect(function()
            if activeKeybindButton and activeKeybindButton ~= button then
                setKeybindButtonVisual(activeKeybindButton, false)
            end

            activeKeybindButton = button
            setKeybindButtonVisual(button, true)
        end)

        -- No bounce on initial bind.
        updateKeybindButtonSize(button, false)

        -- If this keybind is linked to a checkbox toggle, bounce only when the user toggles it on/off.
        do
            local target = button:FindFirstChild("KeybindTarget")
            if target and target:IsA("ObjectValue") then
                local checkbox = target.Value
                if typeof(checkbox) == "Instance" and checkbox:IsA("TextButton") then
                    local previousChecked = (checkbox:GetAttribute("AsteriaChecked") == true)
                    checkbox:GetAttributeChangedSignal("AsteriaChecked"):Connect(function()
                        local nowChecked = (checkbox:GetAttribute("AsteriaChecked") == true)
                        if nowChecked ~= previousChecked then
                            previousChecked = nowChecked
                            button:SetAttribute("AsteriaKeybindJustChanged", true)
                            if keybindsDisplay then
                                keybindsDisplay:ScheduleRefresh()
                            end
                        end
                    end)
                end
            end
        end

        if keybindsDisplay then
            keybindsDisplay:ScheduleRefresh()
        end
    end

    local function getKeybindTargetCheckbox(button)
        local target = button:FindFirstChild("KeybindTarget")
        if target and target:IsA("ObjectValue") then
            local v = target.Value
            if typeof(v) == "Instance" and v:IsA("TextButton") then
                return v
            end
        end
        return nil
    end

    local function removeOwnerFromKeyMap(keyName, button)
        local owner = keybindOwnerByKeyName[keyName]
        if not owner then
            return
        end

        if owner == button then
            keybindOwnerByKeyName[keyName] = nil
            return
        end

        if type(owner) == "table" then
            for i = #owner, 1, -1 do
                if owner[i] == button then
                    table.remove(owner, i)
                end
            end
            if #owner == 0 then
                keybindOwnerByKeyName[keyName] = nil
            elseif #owner == 1 and not multiKeybindEnabled then
                keybindOwnerByKeyName[keyName] = owner[1]
            end
        end
    end

    local function clearKeybindForButton(button, animate)
        if not button then
            return
        end

        local previousKey = button:GetAttribute("AsteriaKeybindKeyName")
        if type(previousKey) == "string" then
            removeOwnerFromKeyMap(previousKey, button)
        end
        button:SetAttribute("AsteriaKeybindKeyName", nil)

        button.Text = "None"
        button:SetAttribute("AsteriaKeybindDefaultText", "None")

        local cb = keybindChangedCallbackByButton[button]
        if cb then
            cb(nil)
        end

        if animate == nil then
            animate = true
        end

        if animate then
            button:SetAttribute("AsteriaKeybindJustChanged", true)
        end
        updateKeybindButtonSize(button, animate)

        if keybindsDisplay then
            keybindsDisplay:ScheduleRefresh()
        end
    end

    local function enforceUniqueKeybinds()
        for keyName, owner in pairs(keybindOwnerByKeyName) do
            if type(owner) == "table" then
                local keep = owner[1]
                local toClear = {}
                for i = 2, #owner do
                    toClear[#toClear + 1] = owner[i]
                end
                for _, btn in ipairs(toClear) do
                    if btn and btn.Parent ~= nil then
                        clearKeybindForButton(btn, false)
                    end
                end
                keybindOwnerByKeyName[keyName] = keep
            end
        end
    end

    local function setKeybindForButton(button, keyCode)
        if not button or not keyCode then
            return
        end

        local keyName = keyCode.Name
        local previousKey = button:GetAttribute("AsteriaKeybindKeyName")
        if type(previousKey) == "string" then
            removeOwnerFromKeyMap(previousKey, button)
        end

        local existingOwner = keybindOwnerByKeyName[keyName]
        if not multiKeybindEnabled then
            if existingOwner and existingOwner ~= button then
                if typeof(existingOwner) == "Instance" then
                    clearKeybindForButton(existingOwner, false)
                elseif type(existingOwner) == "table" then
                    local ownersCopy = {}
                    for _, o in ipairs(existingOwner) do
                        if o ~= button then
                            ownersCopy[#ownersCopy + 1] = o
                        end
                    end
                    for _, o in ipairs(ownersCopy) do
                        clearKeybindForButton(o, false)
                    end
                end
            end
            keybindOwnerByKeyName[keyName] = button
        else
            if not existingOwner then
                keybindOwnerByKeyName[keyName] = button
            elseif existingOwner == button then
                -- already owned
            elseif type(existingOwner) == "table" then
                local already = false
                for _, o in ipairs(existingOwner) do
                    if o == button then
                        already = true
                        break
                    end
                end
                if not already then
                    table.insert(existingOwner, button)
                end
            else
                keybindOwnerByKeyName[keyName] = { existingOwner, button }
            end
        end
        button:SetAttribute("AsteriaKeybindKeyName", keyName)

        button.Text = keyName
        button:SetAttribute("AsteriaKeybindDefaultText", keyName)

        -- Mark as changed so only this keybind "bounces" in the floating display.
        button:SetAttribute("AsteriaKeybindJustChanged", true)

        local cb = keybindChangedCallbackByButton[button]
        if cb then
            cb(keyCode)
        end

        -- Only animate the button the user actually changed.
        updateKeybindButtonSize(button, true)

        if keybindsDisplay then
            keybindsDisplay:ScheduleRefresh()
        end
    end

