        local function pointInFrame(point, frame)
            local pos = frame.AbsolutePosition
            local size = frame.AbsoluteSize
            return point.X >= pos.X and point.X <= pos.X + size.X and point.Y >= pos.Y and point.Y <= pos.Y + size.Y
        end

