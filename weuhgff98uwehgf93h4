            local function getBestCommandMatch(prefix)
                prefix = normalizeCommandText(prefix)
                if prefix == "" then
                    return "reload", commandSpecs.reload
                end

                local bestName, bestSpec
                for name, spec in pairs(commandSpecs) do
                    if string.sub(name, 1, #prefix) == prefix then
                        if not bestName or #name < #bestName then
                            bestName = name
                            bestSpec = spec
                        end
                    end
                end
                return bestName, bestSpec
            end

            local function hasAnyCommandMatch(prefix)
                prefix = normalizeCommandText(prefix)
                if prefix == "" then
                    return false
                end
                for name, _ in pairs(commandSpecs) do
                    if string.sub(name, 1, #prefix) == prefix then
                        return true
                    end
                end
                return false
            end

            local hintTween = nil
            local hintToken = 0
            local function setHintHeight(targetHeight)
                hintToken += 1
                local myToken = hintToken

                if hintTween then
                    hintTween:Cancel()
                    hintTween = nil
                end

                local info = TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                hintTween = TweenService:Create(commandHintRow, info, {
                    Size = UDim2.new(1, 0, 0, math.max(0, tonumber(targetHeight) or 0)),
                })
                hintTween:Play()
                hintTween.Completed:Connect(function()
                    if myToken ~= hintToken then
                        return
                    end
                    if (tonumber(targetHeight) or 0) <= 0 then
                        commandHintTitle.Text = ""
                        commandHintDesc.Text = ""
                    end
                end)
            end

            local function setHintVisible(isVisible)
